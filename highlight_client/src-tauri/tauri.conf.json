{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI切片神器",
  "version": "0.1.0",
  "identifier": "com.local.highlight-client",
  "build": {
    "beforeDevCommand": "python3 server.py",
    "beforeBuildCommand": "",
    "devUrl": "http://127.0.0.1:8765",
    "frontendDist": "../tauri-dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI切片神器",
        "width": 1280,
        "height": 860,
        "url": "http://127.0.0.1:8765"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/highlight-server"
    ],
    "resources": [
      "../README.md"
    ],
    "macOS": {
      "signingIdentity": "-",
      "hardenedRuntime": false
    }
  }
}
